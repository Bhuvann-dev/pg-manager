rules_version = '2';

// PG Manager — Firebase Storage security rules.
//
// Tenant ID documents (Aadhaar) are private PII. They live under an
// owner-scoped path and may only be read or written by the owning account.
// See docs/data-model.md for the storage layout.

service firebase.storage {
  match /b/{bucket}/o {

    // owners/{ownerUid}/tenants/{tenantId}/{file}
    match /owners/{ownerUid}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == ownerUid;
    }

    // Everything else is denied by default.
  }
}
